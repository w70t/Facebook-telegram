# ====== Telegram (الحساب الشخصي للقراءة) ======
# من https://my.telegram.org  ->  API development tools
API_ID=1234567
API_HASH=0123456789abcdef0123456789abcdef

# ====== بوت المراجعة (Bot الذي تضغط أزراره) ======
# من @BotFather
BOT_TOKEN=123456:ABC-DEF...

# القنوات المصدر التي ينسخ منها (افصل بفاصلة)
# تقبل @username أو معرّف رقمي مثل -1001234567890
SOURCE_CHANNELS=@source_news_channel

# المجموعة/المحادثة التي يرسل فيها البوت المنشور للمراجعة
# (أنشئ قروب، أضف الأدمنين والبوت، واستخدم الأمر /id لمعرفة الرقم)
REVIEW_CHAT_ID=-1009876543210

# معرّفات الأدمنين المسموح لهم بالضغط على الأزرار (افصل بفاصلة)
ADMIN_IDS=11111111,22222222

# ====== Facebook ======
# معرّف الصفحة + Page Access Token طويل الأمد
FB_PAGE_ID=1234567890
FB_PAGE_TOKEN=EAAB...long-lived-page-token...

# مجلد التنزيل المؤقت للوسائط (اختياري)
DOWNLOAD_DIR=downloads
