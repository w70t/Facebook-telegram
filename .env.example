# ╔══════════════════════════════════════════════════════════════╗
# ║  انسخ هذا الملف باسم  .env  ثم استبدل ما بين <> بقيمك أنت     ║
# ║  الأمر:  cp .env.example .env                                  ║
# ║  الشرح الكامل لكل قيمة في ملف SETUP_AR.md                      ║
# ╚══════════════════════════════════════════════════════════════╝

# ====== (1) Telegram — الحساب الشخصي للقراءة ======
# من https://my.telegram.org  ->  API development tools
API_ID=<ضع_API_ID_هنا>
API_HASH=<ضع_API_HASH_هنا>

# ====== (2) بوت المراجعة — الذي تضغط أزراره ======
# من @BotFather
BOT_TOKEN=<ضع_توكن_البوت_هنا>

# ====== (3) القنوات المصدر (اختياري) ======
# تقدر تتركه فارغاً وتضيف القنوات من داخل البوت بأمر /addsource
# أو ضع قناة/عدة قنوات مفصولة بفاصلة: @channel1,@channel2 أو -1001234567890
SOURCE_CHANNELS=

# ====== (4) قروب المراجعة الذي يرسل فيه البوت المنشورات ======
# أنشئ قروب، أضف الأدمنين والبوت، ثم أرسل /id داخله لمعرفة الرقم
REVIEW_CHAT_ID=<معرّف_القروب>

# ====== (5) الأدمنون المسموح لهم بالضغط على الأزرار ======
# أرسل /id في القروب ليعطيك معرّفك (افصل بفاصلة لعدة أدمنين)
ADMIN_IDS=<معرّفك_الرقمي>

# ====== (6) Facebook — الصفحة والنشر ======
# من Graph API Explorer ثم GET /me/accounts (انظر SETUP_AR.md)
FB_PAGE_ID=<معرّف_الصفحة>
FB_PAGE_TOKEN=<توكن_الصفحة_الطويل>

# ====== إعداد اختياري ======
DOWNLOAD_DIR=downloads
